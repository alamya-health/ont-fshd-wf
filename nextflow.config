report.overwrite = true
dag.overwrite = true

docker.enabled = true
conda.enabled = false

def FSHD_BUNDLE_S3_PREFIX = 's3://alamyasingapore-nus-lab-production-processing/reference-genome-and-databases/FSHD_Bundle'

aws {
    maxConnections = 20
    connectionTimeout = 10000
    uploadStorageClass = "STANDARD"
}

wave {
    enabled = true
    strategy = ['container']
}

params {
    aws_account_id = '160433694210'
    aws_region = 'ap-southeast-1'
    ecr_repo = 'ont-fshd-wf'
    image_tag = '20260320-psfix2'
    profile_fshd_methylation_image_tag = ''
    call_fshd_variants_image_tag = ''

    samplesheet = ""
    sample_id = ""
    input_aligned_bam = ""
    input_aligned_bai = ""
    input_ubam_dir = ""
    reuse_input_t2t_alignment = false

    t2t_ref_fasta = "${FSHD_BUNDLE_S3_PREFIX}/t2t/chm13/chm13v2.0.fa"
    t2t_ref_mmi = ""
    blast_db_dir = "${projectDir}/ressources/blast_db"
    fshd_locus_bed = "${projectDir}/assets/fshd_locus_t2t.bed"
    methylation_regions_bed = "${projectDir}/assets/fshd_methylation_regions_t2t.bed"
    fshd_analysis_rscript = "${projectDir}/ressources/tools/FSHD_analysis.R"

    run_methylation = true
    run_variant_calling = false
    contraction_threshold_ru = 10
    minimap2_preset = 'lr:hq'

    hg38_ref_fasta = "${FSHD_BUNDLE_S3_PREFIX}/variant/hg38/hg38_no_alt.fa"
    hg38_ref_mmi = ""
    clair3_model_name = 'r1041_e82_400bps_sup_v500'
    clair3_model_path = ""
    clair3_model_tgz = ""
    clinvar_vcf_gz = "${FSHD_BUNDLE_S3_PREFIX}/variant/clinvar/clinvar.vcf.gz"
    clinvar_vcf_tbi = "${FSHD_BUNDLE_S3_PREFIX}/variant/clinvar/clinvar.vcf.gz.tbi"
    snpeff_data_tgz = "${FSHD_BUNDLE_S3_PREFIX}/variant/snpeff/snpeff_hg38_data.tgz"

    output_dir = ""
}

process {
    errorStrategy = 'retry'
    maxRetries = 2

    withName: 'MERGE_UNALIGNED_BAMS' {
        cpus = 8
        memory = { 32.GB * task.attempt }
    }
    withName: 'ALIGN_READS_TO_T2T' {
        cpus = 8
        memory = { 16.GB * task.attempt }
    }
    withName: 'EXTRACT_FSHD_LOCUS' {
        cpus = 4
        memory = { 8.GB * task.attempt }
    }
    withName: 'ALIGN_READS_TO_HG38' {
        cpus = 8
        memory = { 16.GB * task.attempt }
    }
    withName: 'BLAST_FSHD_READS' {
        cpus = 4
        memory = { 8.GB * task.attempt }
    }
    withName: 'PAS_CHECK_FSHD' {
        cpus = 1
        memory = { 2.GB * task.attempt }
    }
    withName: 'CLASSIFY_FSHD_READS' {
        cpus = 2
        memory = { 6.GB * task.attempt }
    }
    withName: 'EXTRACT_CLASSIFIED_READ_SUBSETS' {
        cpus = 4
        memory = { 8.GB * task.attempt }
    }
    withName: 'SUMMARIZE_HAPLOTAGS' {
        cpus = 1
        memory = { 4.GB * task.attempt }
    }
    withName: 'PROFILE_FSHD_METHYLATION' {
        cpus = 6
        memory = { 12.GB * task.attempt }
    }
    withName: 'CALL_FSHD_VARIANTS' {
        cpus = 8
        memory = { 24.GB * task.attempt }
    }
    withName: 'BUILD_FSHD_REPORT' {
        cpus = 2
        memory = { 4.GB * task.attempt }
    }
    withName: 'SUMMARIZE_COHORT' {
        cpus = 1
        memory = { 2.GB * task.attempt }
    }
}

def AWS_ACCOUNT_ID = params.aws_account_id ?: System.getenv('AWS_ACCOUNT_ID') ?: ''
def AWS_REGION = params.aws_region ?: System.getenv('AWS_REGION') ?: 'ap-southeast-1'
def ECR_REPO = params.ecr_repo ?: System.getenv('ECR_REPO') ?: 'ont-fshd-wf'
def TAG = params.image_tag ?: System.getenv('TAG') ?: 'latest'
def PROFILE_FSHD_METHYLATION_TAG = params.profile_fshd_methylation_image_tag ?: TAG
def CALL_FSHD_VARIANTS_TAG = params.call_fshd_variants_image_tag ?: TAG

if( !AWS_ACCOUNT_ID ) {
    throw new IllegalArgumentException("Missing AWS account id. Set params.aws_account_id or env AWS_ACCOUNT_ID.")
}

def ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO}"

process {
    withName: MERGE_UNALIGNED_BAMS              { container = "${ECR_REGISTRY}:merge-unaligned-bams-${TAG}" }
    withName: ALIGN_READS_TO_T2T                { container = "${ECR_REGISTRY}:align-reads-to-t2t-${TAG}" }
    withName: EXTRACT_FSHD_LOCUS                { container = "${ECR_REGISTRY}:extract-fshd-locus-${TAG}" }
    withName: ALIGN_READS_TO_HG38               { container = "${ECR_REGISTRY}:align-reads-to-hg38-${TAG}" }
    withName: BLAST_FSHD_READS                  { container = "${ECR_REGISTRY}:blast-fshd-reads-${TAG}" }
    withName: PAS_CHECK_FSHD                    { container = "${ECR_REGISTRY}:pas-check-fshd-${TAG}" }
    withName: CLASSIFY_FSHD_READS               { container = "${ECR_REGISTRY}:classify-fshd-reads-${TAG}" }
    withName: EXTRACT_CLASSIFIED_READ_SUBSETS   { container = "${ECR_REGISTRY}:extract-classified-read-subsets-${TAG}" }
    withName: SUMMARIZE_HAPLOTAGS               { container = "${ECR_REGISTRY}:summarize-haplotags-${TAG}" }
    withName: PROFILE_FSHD_METHYLATION          { container = "${ECR_REGISTRY}:profile-fshd-methylation-${PROFILE_FSHD_METHYLATION_TAG}" }
    withName: CALL_FSHD_VARIANTS                { container = "${ECR_REGISTRY}:call-fshd-variants-${CALL_FSHD_VARIANTS_TAG}" }
    withName: BUILD_FSHD_REPORT                 { container = "${ECR_REGISTRY}:build-fshd-report-${TAG}" }
    withName: SUMMARIZE_COHORT                  { container = "${ECR_REGISTRY}:summarize-cohort-${TAG}" }
}
